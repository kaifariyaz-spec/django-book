{
    "builds":[
        {
            "src": "bookmyseat/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "buildCommand": "bash build.sh"
            }
        }
    ],
    "routes":[
        {
            "src": "/(.*)",
            "dest": "bookmyseat/wsgi.py"
        }
    ]
}